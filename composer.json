{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cboxdk/laravel-nexus",
    "description": "Cbox Nexus — the US economic-nexus engine for Laravel: accumulate a seller's sales per state, detect when a post-Wayfair threshold is crossed, and report where registration is required.",
    "keywords": ["cbox", "nexus", "economic-nexus", "wayfair", "sales-tax", "us", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "cboxdk/laravel-geo": "^0.4 || ^0.5",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.5 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Cbox\\Nexus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cbox\\Nexus\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "analyse": "phpstan analyse --no-progress --memory-limit=1G",
        "test": "pest",
        "license-check": "@php bin/check-licenses.php",
        "sbom": "@php bin/generate-sbom.php",
        "qa": [
            "@lint",
            "@analyse",
            "@test",
            "@license-check",
            "@composer audit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cbox\\Nexus\\NexusServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
